{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "bash",
      "args": ["./scripts/run.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Run Streamlit App (Windows)",
      "type": "shell",
      "command": "powershell",
      "args": [".\\scripts\\run-win.ps1"],
      "group": "test",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Debug Streamlit App",
      "type": "shell",
      "command": "bash",
      "args": ["./scripts/run-debug.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Sync requirements.txt file",
      "type": "shell",
      "command": "uv pip compile pyproject.toml -o requirements.txt",
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
